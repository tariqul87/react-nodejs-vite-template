NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://your-frontend.example.com

POSTGRES_DB=template_prod
POSTGRES_USER=template_user
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://template_user:replace-with-strong-password@postgres:5432/template_prod

JWT_ACCESS_SECRET=replace-with-long-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=Password123!
