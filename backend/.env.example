# Runtime
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Postgres
POSTGRES_DB=template_local
POSTGRES_USER=template_user
POSTGRES_PASSWORD=template_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://template_user:template_password@localhost:5432/template_local

# JWT (replace with secure values per environment)
JWT_ACCESS_SECRET=replace-with-at-least-32-characters-access-secret
JWT_REFRESH_SECRET=replace-with-at-least-32-characters-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Demo account for quick template testing
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=Password123!

# HttpOnly refresh cookie name (default: refresh_token)
# REFRESH_COOKIE_NAME=refresh_token
