JWT_REFRESH_SECRET=dev-refresh-secret-change-me-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=Password123!
