# Base URL for the backend API (no trailing slash).
# Leave unset for local dev and Docker builds so the browser uses same-origin `/api` (required for HttpOnly refresh cookies).
# Only set if the SPA and API are intentionally on different origins (needs extra CORS/cookie configuration).
# VITE_API_URL=http://localhost:3001
# VITE_APP_TITLE=React + Node.js Template
